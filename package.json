{
	"name": "@jonahsnider/benchmark",
	"version": "6.0.1",
	"bugs": {
		"url": "https://github.com/jonahsnider/benchmark/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/jonahsnider/benchmark.git"
	},
	"license": "Apache-2.0",
	"author": {
		"name": "Jonah Snider",
		"email": "jonah@jonahsnider.com",
		"url": "https://jonahsnider.com"
	},
	"sideEffects": false,
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.cts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		}
	},
	"main": "./dist/index.cjs",
	"types": "./dist/index.d.cts",
	"files": [
		"dist",
		"!dist/{test,examples}"
	],
	"scripts": {
		"build": "zshy",
		"docs": "typedoc",
		"lint": "xo",
		"style": "prettier --check .",
		"test": "ava",
		"test:coverage": "c8 --reporter lcov --reporter text-summary --include 'src/**/*.ts' --exclude 'src/index.ts' --all ava",
		"validate-api": "api-extractor run",
		"validate-api:local": "api-extractor run --local --verbose"
	},
	"prettier": "@jonahsnider/prettier-config",
	"dependencies": {
		"@jonahsnider/util": "13.0.0",
		"tslib": "2.8.1"
	},
	"devDependencies": {
		"@jonahsnider/prettier-config": "1.1.2",
		"@jonahsnider/xo-config": "6.0.0",
		"@microsoft/api-extractor": "7.58.7",
		"@tsconfig/node22": "22.0.5",
		"@types/node": "22.19.17",
		"ava": "7.0.0",
		"c8": "11.0.0",
		"eslint-plugin-prettier": "5.5.5",
		"jest-mock": "30.3.0",
		"prettier": "3.8.3",
		"typedoc": "0.28.19",
		"typescript": "6.0.3",
		"xo": "1.2.3",
		"zshy": "0.7.0"
	},
	"zshy": "./src/index.ts",
	"packageManager": "yarn@4.14.1",
	"engines": {
		"node": ">=22.0.0"
	},
	"publishConfig": {
		"access": "public"
	},
	"module": "./dist/index.js"
}
